# Copy to .env for local development.
# Override per-app values in apps/<app>/.env if needed.

# ---------- Database ----------
DATABASE_URL="postgresql://abd:abd_dev_password@localhost:5432/abd?schema=public"

# ---------- Redis ----------
REDIS_URL="redis://localhost:6379"

# ---------- API (apps/api) ----------
API_PORT=3001
API_HOST="0.0.0.0"
JWT_SECRET="change-me-in-production"
JWT_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30
CORS_ORIGIN="http://localhost:3000"

# ---------- Gateway TCP Server (apps/gw-server) ----------
GW_TCP_PORT=8901
GW_TCP_HOST="0.0.0.0"
GW_HEARTBEAT_TIMEOUT_MS=90000
GW_REGISTER_TIMEOUT_MS=10000

# ---------- Web (apps/web) ----------
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
NEXT_PUBLIC_AMAP_KEY=""

# ---------- Aliyun (production) ----------
# Leave empty in dev
ALIYUN_OSS_REGION=""
ALIYUN_OSS_BUCKET=""
ALIYUN_OSS_ACCESS_KEY_ID=""
ALIYUN_OSS_ACCESS_KEY_SECRET=""
ALIYUN_SMS_ACCESS_KEY_ID=""
ALIYUN_SMS_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""

# ---------- Push (production) ----------
APNS_KEY_ID=""
APNS_TEAM_ID=""
HUAWEI_PUSH_APP_ID=""
HUAWEI_PUSH_APP_SECRET=""
XIAOMI_PUSH_APP_SECRET=""

# ---------- Log ----------
LOG_LEVEL="debug"
NODE_ENV="development"
